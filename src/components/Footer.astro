---
import { boat } from '../data/content';
---

<footer>
  <div class="brand">{boat.name}</div>
  <div class="meta">
    S/Y {boat.type}<br />
    {boat.club} · Nacka<br />
    Stockholm, Sverige
  </div>
</footer>

<style>
  footer {
    background: var(--color-ink);
    padding: 3rem var(--section-x);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .brand {
    font-family: var(--font-serif);
    font-style: italic;
    color: white;
    font-size: 1.4rem;
  }

  .meta {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.3);
    text-transform: uppercase;
    text-align: right;
    line-height: 2;
  }

  @media (max-width: 768px) {
    footer {
      flex-direction: column;
      gap: 1.5rem;
      align-items: flex-start;
      padding: 2rem 1.5rem;
    }
    .meta { text-align: left; }
  }
</style>
