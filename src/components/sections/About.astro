---
import { about } from '../../data/content';
---

<section id="om">
  <div class="inner about-grid">
    <div class="text reveal">
      <h2 class="section-title" set:html={about.title} />
      {about.paragraphs.map((p) => <p>{p}</p>)}
      <div class="specs">
        {about.specs.map((spec) => (
          <div class="spec">
            <div class="spec-label">{spec.label}</div>
            <div class="spec-value">{spec.value}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .about-grid {
    max-width: 700px;
  }

  .text p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--color-text-body);
    margin-bottom: 1.5rem;
    font-weight: 300;
    max-width: 65ch;
  }

  .specs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem 3rem;
    margin-top: 2.5rem;
  }

  .spec {
    padding: 0;
  }

  .spec-label {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-horizon-text);
    margin-bottom: 0.3rem;
  }

  .spec-value {
    font-family: var(--font-hand);
    font-size: 1.4rem;
    color: var(--color-sea);
  }

</style>
