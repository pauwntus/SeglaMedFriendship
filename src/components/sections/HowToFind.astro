---
import { howToFind } from '../../data/content';
---

<section>
  <div class="inner">
    <h2 class="section-title reveal" set:html={howToFind.title} />
    <p class="intro reveal">{howToFind.intro}</p>
    <div class="details reveal">
      {
        howToFind.details.map((detail) => (
          <div class="detail">
            <div class="detail-label">{detail.label}</div>
            <div class="detail-value">{detail.value}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  section {
    text-align: center;
  }

  .section-label,
  .section-title { text-align: center; }

  .section-title { max-width: 600px; margin-left: auto; margin-right: auto; }

  .intro {
    max-width: 500px;
    margin: 0 auto 3rem;
    font-size: 1.05rem;
    color: var(--color-text-subtle);
    line-height: 1.7;
    font-weight: 300;
  }

  .details {
    display: inline-flex;
    gap: 3rem;
    padding: 2rem 3rem;
    background: var(--color-light);
    text-align: left;
    flex-wrap: wrap;
  }

  .detail {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .detail-label {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-horizon);
  }

  .detail-value {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    color: var(--color-sea);
  }

  @media (max-width: 768px) {
    .details {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      padding: 1.5rem;
      width: 100%;
      text-align: left;
    }
  }
</style>
