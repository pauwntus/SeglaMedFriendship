<style>
  .map {
    margin: 0 0 3rem;
    max-width: 760px;
    overflow-x: auto;
  }

  .map svg {
    width: 100%;
    height: auto;
    min-width: 560px;
    display: block;
  }

  .water {
    fill: rgba(77, 122, 110, 0.16);
    stroke: var(--color-ink);
    stroke-width: 2.4;
    stroke-linejoin: round;
  }

  .wave-sq {
    fill: none;
    stroke: rgba(22, 33, 29, 0.4);
    stroke-width: 2;
    stroke-linecap: round;
  }

  .ink {
    fill: none;
    stroke: var(--color-ink);
    stroke-width: 2.4;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .ink.station { fill: var(--color-ink); }

  .stop {
    fill: none;
    stroke: var(--color-ink);
    stroke-width: 2.4;
  }

  .route {
    fill: none;
    stroke: var(--color-sun-deep);
    stroke-width: 3.2;
    stroke-linecap: round;
    stroke-dasharray: 9 8;
  }

  .road,
  .road path {
    fill: none;
    stroke: rgba(22, 33, 29, 0.4);
    stroke-width: 2;
    stroke-linecap: round;
  }

  .rail {
    fill: none;
    stroke: rgba(22, 33, 29, 0.35);
    stroke-width: 2;
    stroke-dasharray: 2 6;
    stroke-linecap: round;
  }

  .label-water {
    font-family: var(--font-hand);
    font-size: 21px;
    letter-spacing: 0.1em;
    fill: var(--color-horizon-text);
  }

  .label-water.small { font-size: 14px; letter-spacing: 0.08em; }

