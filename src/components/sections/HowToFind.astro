<style>
  .map {
    margin: 0 0 3rem;
    max-width: 760px;
    overflow-x: auto;
  }

  .map svg {
    width: 100%;
    height: auto;
    min-width: 560px;
    display: block;
  }

  .water {
    fill: rgba(77, 122, 110, 0.16);
    stroke: var(--color-ink);
    stroke-width: 2.4;
    stroke-linejoin: round;
  }

  .wave-sq {
    fill: none;
    stroke: rgba(22, 33, 29, 0.4);
    stroke-width: 2;
    stroke-linecap: round;
  }

  .ink {
    fill: none;
    stroke: var(--color-ink);
    stroke-width: 2.4;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .ink.station { fill: var(--color-ink); }

  .stop {
    fill: none;
    stroke: var(--color-ink);
    stroke-width: 2.4;
  }

  .route {
    fill: none;
    stroke: var(--color-sun-deep);
    stroke-width: 3.2;
    stroke-linecap: round;
    stroke-dasharray: 9 8;
  }

  .road,
  .road path {
    fill: none;
    stroke: rgba(22, 33, 29, 0.4);
    stroke-width: 2;
    stroke-linecap: round;
  }

  .rail {
    fill: none;
    stroke: rgba(22, 33, 29, 0.35);
    stroke-width: 2;
    stroke-dasharray: 2 6;
    stroke-linecap: round;
  }

  .label-water {
    font-family: var(--font-hand);
    font-size: 21px;
    letter-spacing: 0.1em;
    fill: var(--color-horizon-text);
  }

  .label-water.small { font-size: 14px; letter-spacing: 0.08em; }

  .label-place {
    font-family: var(--font-hand);
    font-size: 22px;
    fill: var(--color-ink);
  }

  .label-club {
    font-family: var(--font-hand);
    font-size: 26px;
    fill: var(--color-ink);
  }

  .label-route {
    font-family: var(--font-hand);
    font-size: 20px;
    fill: var(--color-sun-deep);
  }

  .note {
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 500;
    fill: var(--color-text-subtle);
  }

  .intro {
    max-width: 500px;
    margin: 0 0 3rem;
    font-size: 1.05rem;
    color: var(--color-text-subtle);
    line-height: 1.7;
    font-weight: 300;
  }

  .details {
    display: inline-flex;
    gap: 3rem;
    padding: 2rem;
    background: var(--color-foam);
    flex-wrap: wrap;
  }

  .detail {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .detail-label {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-horizon-text);
  }

  .detail-value {
    font-family: var(--font-hand);
    font-size: 1.05rem;
    color: var(--color-sea);
  }

  .detail-value a {
    color: var(--color-sea);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--color-sun);
  }

  @media (max-width: 768px) {
    .details {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      padding: 2rem;
      width: 100%;
    }
  }
</style>
