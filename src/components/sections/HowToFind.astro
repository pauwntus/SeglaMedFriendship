---
import { howToFind } from '../../data/content';
---

<section id="hitta">
  <div class="inner">
    <h2 class="section-title reveal" set:html={howToFind.title} />
    <p class="intro reveal">{howToFind.intro}</p>

    <figure class="map reveal">
      <svg
        viewBox="0 0 800 560"
        role="img"
        aria-label="Handritad karta: från busshållplatsen på Henriksdalsberget går du trapporna ner till klubben, cirka 7 minuter. Från Sickla station följer du gångvägen längs Svindersviken, cirka 15 minuter."
      >
        <!-- Svindersviken -->
        <path
          class="water"
          d="M 266 436
             C 272 404, 282 378, 296 344
             C 322 292, 372 240, 448 196
             C 520 154, 640 96, 788 52
             L 788 128
             C 660 158, 552 210, 452 282
             C 392 326, 348 372, 324 416
             C 314 434, 306 446, 300 456
             Z"
        />
        <path class="wave-sq" d="M 470 250 c 10 -7 20 4 30 -3" />
        <path class="wave-sq" d="M 560 200 c 10 -7 20 4 30 -3" />
        <path class="wave-sq" d="M 380 330 c 9 -6 18 4 27 -3" />

        <text class="label-water" x="440" y="248" transform="rotate(-27 480 240)">SVINDERSVIKEN</text>
        <text class="label-place" x="620" y="82">Kvarnholmen</text>
        <text class="note" x="672" y="164">mot Saltsjön →</text>

        <!-- Henriksdalsberget: hus + hållplats -->
        <g class="ink">
          <path d="M 82 128 l 34 0 l 0 -26 l -34 0 z M 86 102 l 13 -11 l 13 11" />
          <path d="M 128 138 l 34 0 l 0 -26 l -34 0 z M 132 112 l 13 -11 l 13 11" />
          <path d="M 96 172 l 34 0 l 0 -26 l -34 0 z M 100 146 l 13 -11 l 13 11" />
        </g>
        <text class="label-place" x="52" y="72">Henriksdalsberget</text>
        <circle class="stop" cx="104" cy="208" r="7" />
        <text class="note" x="120" y="204">buss 53/55</text>
        <text class="note" x="120" y="222">från Slussen</text>

        <!-- Rutt A: trapporna ner -->
        <path class="route" d="M 112 220 C 136 248, 158 268, 178 290 C 200 314, 234 330, 268 338" />
        <g class="ink stairs">
          <path d="M 168 272 l 12 0 l 0 9 l 12 0 l 0 9 l 12 0" />
        </g>
        <text class="label-route" x="60" y="316">trapporna ner!</text>
        <text class="note" x="78" y="336">ca 7 min</text>

        <!-- Klubben + Friendship -->
        <g class="ink boat">
          <path d="M 296 322 c 12 10 34 10 44 0 l 8 -6 l -60 0 z" />
          <path d="M 318 316 l 0 -34" />
          <path d="M 318 284 c 12 6 20 16 22 28 l -22 0 z" />
          <path d="M 318 284 l -12 6 l 12 4" />
        </g>
        <text class="label-club" x="84" y="386">Svindersviks BK</text>
        <text class="label-route" x="104" y="412">här ligger hon!</text>
        <path class="ink arrow" d="M 296 404 C 316 392, 326 368, 322 344 M 322 344 l -9 11 M 322 344 l 9 10" />

        <!-- Rutt B: gångvägen från Sickla -->
        <path class="route" d="M 452 496 C 424 484, 390 476, 352 470 C 312 464, 284 442, 276 408 C 272 388, 272 366, 278 348" />
        <text class="label-route" x="420" y="420">gångvägen</text>
        <text class="label-route" x="428" y="444">längs viken</text>
        <text class="note" x="446" y="464">ca 15 min</text>

        <!-- Värmdöleden + Sickla -->
        <g class="road">
          <path d="M 40 516 C 200 508, 420 502, 560 492 C 640 486, 700 482, 762 476" />
          <path d="M 40 532 C 200 524, 420 518, 560 508 C 640 502, 700 498, 762 492" />
        </g>
        <text class="note" x="608" y="530">Värmdöleden</text>
        <rect class="ink station" x="446" y="500" width="18" height="18" />
        <text class="label-place" x="252" y="552">Sickla station</text>
        <text class="note" x="474" y="552">tvärbanan &amp; Saltsjöbanan</text>

        <!-- Kompass + brasklapp -->
        <g class="ink compass">
          <path d="M 720 336 l 0 -44 M 720 292 l -9 14 M 720 292 l 9 14" />
        </g>
        <text class="label-place" x="712" y="368">N</text>
        <text class="note" x="626" y="396">(ej helt skalenlig)</text>
      </svg>
    </figure>

    <div class="details reveal">
      {
        howToFind.details.map((detail) => (
          <div class="detail">
            <div class="detail-label">{detail.label}</div>
            <div class="detail-value">
              {'href' in detail && detail.href ? (
                <a href={detail.href} target="_blank" rel="noopener">{detail.value}</a>
              ) : (
                detail.value
              )}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .map {
    margin: 0 0 3rem;
    max-width: 760px;
    overflow-x: auto;
  }

  .map svg {
    width: 100%;
    height: auto;
    min-width: 560px;
    display: block;
  }

  .water {
    fill: rgba(77, 122, 110, 0.16);
    stroke: var(--color-ink);
    stroke-width: 2.4;
    stroke-linejoin: round;
  }

  .wave-sq {
    fill: none;
    stroke: rgba(22, 33, 29, 0.4);
    stroke-width: 2;
    stroke-linecap: round;
  }

  .ink {
    fill: none;
    stroke: var(--color-ink);
    stroke-width: 2.4;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .ink.station { fill: var(--color-ink); }

  .stop {
    fill: none;
    stroke: var(--color-ink);
    stroke-width: 2.4;
  }

  .route {
    fill: none;
    stroke: var(--color-sun-deep);
    stroke-width: 3.2;
    stroke-linecap: round;
    stroke-dasharray: 9 8;
  }

  .road path {
    fill: none;
    stroke: rgba(22, 33, 29, 0.45);
    stroke-width: 2;
  }

  .label-water {
    font-family: var(--font-hand);
    font-size: 25px;
    letter-spacing: 0.14em;
    fill: var(--color-horizon-text);
  }

  .label-place {
    font-family: var(--font-hand);
    font-size: 22px;
    fill: var(--color-ink);
  }

  .label-club {
    font-family: var(--font-hand);
    font-size: 26px;
    fill: var(--color-ink);
  }

  .label-route {
    font-family: var(--font-hand);
    font-size: 20px;
    fill: var(--color-sun-deep);
  }

  .note {
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 500;
    fill: var(--color-text-subtle);
  }

  .intro {
    max-width: 500px;
    margin: 0 0 3rem;
    font-size: 1.05rem;
    color: var(--color-text-subtle);
    line-height: 1.7;
    font-weight: 300;
  }

  .details {
    display: inline-flex;
    gap: 3rem;
    padding: 2rem;
    background: var(--color-foam);
    flex-wrap: wrap;
  }

  .detail {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .detail-label {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-horizon-text);
  }

  .detail-value {
    font-family: var(--font-hand);
    font-size: 1.05rem;
    color: var(--color-sea);
  }

  .detail-value a {
    color: var(--color-sea);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--color-sun);
  }

  @media (max-width: 768px) {
    .details {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      padding: 2rem;
      width: 100%;
    }
  }
</style>
