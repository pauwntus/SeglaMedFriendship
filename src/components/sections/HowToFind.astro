---
import { howToFind } from '../../data/content';
---

<section id="hitta">
  <div class="inner">
    <h2 class="section-title reveal" set:html={howToFind.title} />
    <p class="intro reveal">{howToFind.intro}</p>
    <div class="details reveal">
      {
        howToFind.details.map((detail) => (
          <div class="detail">
            <div class="detail-label">{detail.label}</div>
            <div class="detail-value">
              {'href' in detail && detail.href ? (
                <a href={detail.href} target="_blank" rel="noopener">{detail.value}</a>
              ) : (
                detail.value
              )}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .intro {
    max-width: 500px;
    margin: 0 0 3rem;
    font-size: 1.05rem;
    color: var(--color-text-subtle);
    line-height: 1.7;
    font-weight: 300;
  }

  .details {
    display: inline-flex;
    gap: 3rem;
    padding: 2rem;
    background: var(--color-foam);
    flex-wrap: wrap;
  }

  .detail {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .detail-label {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-horizon-text);
  }

  .detail-value {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    color: var(--color-sea);
  }

  .detail-value a {
    color: var(--color-sea);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--color-sun);
  }

  @media (max-width: 768px) {
    .details {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      padding: 2rem;
      width: 100%;
    }
  }
</style>
