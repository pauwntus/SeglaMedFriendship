---
import { prep } from '../../data/content';
---

<section id="infor">
  <div class="inner">
    <h2 class="section-title reveal" set:html={prep.title} />
    <p class="intro reveal">{prep.intro}</p>
    <div class="grid">
      {
        prep.checklists.map((list) => (
          <div class="card reveal">
            <div class="card-title">{list.title}</div>
            <ul class="list">
              {list.items.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .intro {
    max-width: 55ch;
    font-size: 1.05rem;
    color: var(--color-text-subtle);
    line-height: 1.7;
    font-weight: 300;
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-top: 2.5rem;
  }

  .card {
    background: var(--color-foam);
    padding: 2rem;
  }

  .card-title {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    color: var(--color-sea);
    margin-bottom: 1.2rem;
  }

  .list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .list li {
    font-size: 0.92rem;
    color: var(--color-text-body);
    font-weight: 300;
    line-height: 1.4;
    padding-left: 1.2rem;
    position: relative;
  }

  .list li::before {
    content: '–';
    position: absolute;
    left: 0;
    color: var(--color-salt);
    font-family: var(--font-sans);
  }

  @media (max-width: 768px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
