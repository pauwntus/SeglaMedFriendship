---
import { gallery } from '../../data/content';
---

<section id="bilder">
  <div class="inner">
    <div class="section-label reveal">{gallery.label}</div>
    <h2 class="section-title reveal" set:html={gallery.title} />
    <p class="intro reveal">{gallery.intro}</p>
    <div class="grid reveal">
      {
        gallery.items.map((item, i) => (
          <div class={`item gp-${i + 1}${i === 0 ? ' item--featured' : ''}`}>
            <div class="placeholder">
              <svg
                width={i === 0 ? 40 : 28}
                height={i === 0 ? 40 : 28}
                viewBox="0 0 40 40"
                fill="none"
                aria-hidden="true"
              >
                <circle cx="20" cy="20" r="18" stroke="white" stroke-width="1.5" stroke-dasharray="4 3" />
                <path d="M20 13V27M13 20H27" stroke="white" stroke-width="1.5" />
              </svg>
              <div class="placeholder-label">{item.label}</div>
            </div>
          </div>
        ))
      }
    </div>
    <p class="hint">{gallery.hint}</p>
  </div>
</section>

<style>
  section {
    background: var(--color-ink);
  }

  /* Dark section overrides */
  .section-label { color: rgba(200, 147, 74, 0.8); }
  .section-title { color: white; }

  .intro {
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.5);
    font-weight: 300;
    margin-bottom: 3rem;
    max-width: 500px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.5rem;
  }

  .item {
    background: var(--color-sea);
    border-radius: 2px;
    overflow: hidden;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    transition: transform 0.3s;
  }

  .item:hover { transform: scale(0.98); }

  .item--featured {
    grid-column: span 2;
    grid-row: span 2;
    aspect-ratio: auto;
  }

  .gp-1 { background: linear-gradient(135deg, #1e3a5f, #0d2137); }
  .gp-2 { background: linear-gradient(135deg, #2d5f8a, #1e3a5f); }
  .gp-3 { background: linear-gradient(135deg, #1a4060, #2d5f8a); }
  .gp-4 { background: linear-gradient(135deg, #0d2137, #1e3a5f); }
  .gp-5 { background: linear-gradient(135deg, #2d5f8a, #4a7fa5); }

  .placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 2rem;
  }

  .placeholder svg { opacity: 0.4; }

  .placeholder-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.3);
    text-align: center;
    white-space: pre-line;
  }

  .hint {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.25);
    margin-top: 1.5rem;
    text-transform: uppercase;
  }

  @media (max-width: 768px) {
    .grid { grid-template-columns: repeat(2, 1fr); }
    .item--featured { grid-column: span 2; }
  }

  @media (max-width: 480px) {
    .grid { grid-template-columns: 1fr; }
    .item--featured { grid-column: span 1; aspect-ratio: 1; }
  }
</style>
