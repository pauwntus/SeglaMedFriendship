---
import { Image } from 'astro:assets';
import { gallery } from '../../data/content';

// Bilder läggs i src/assets/bilder/ och kopplas via `src`-fältet i content.ts.
const files = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/bilder/*.{jpg,jpeg,png,webp,avif,JPG,JPEG,PNG,WEBP,AVIF}',
  { eager: true },
);
const imageFor = (src?: string) =>
  src ? files[`../../assets/bilder/${src}`]?.default : undefined;
---

<section id="bilder">
  <div class="inner">
    <h2 class="section-title reveal" set:html={gallery.title} />
    <p class="intro reveal">{gallery.intro}</p>
    <div class="grid reveal">
      {
        gallery.items.map((item) => {
          const img = imageFor(item.src);
          const featured = 'featured' in item && item.featured;
          return (
            <div class={`item${featured ? ' item--featured' : ''}`}>
              {img ? (
                <Image
                  src={img}
                  alt={item.label.replace(/\n/g, ' ')}
                  widths={featured ? [640, 1024, 1600] : [400, 800]}
                  sizes={
                    featured
                      ? '(max-width: 768px) 100vw, 50vw'
                      : '(max-width: 480px) 100vw, (max-width: 768px) 50vw, 25vw'
                  }
                  class="photo"
                />
              ) : (
                <div class="placeholder">
                  <svg
                    width={featured ? 40 : 28}
                    height={featured ? 40 : 28}
                    viewBox="0 0 40 40"
                    fill="none"
                    aria-hidden="true"
                  >
                    <circle cx="20" cy="20" r="18" stroke="white" stroke-width="1.5" stroke-dasharray="4 3" />
                    <path d="M20 13V27M13 20H27" stroke="white" stroke-width="1.5" />
                  </svg>
                  <div class="placeholder-label">{item.label}</div>
                </div>
              )}
            </div>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .intro {
    font-size: 1.05rem;
    color: var(--color-text-subtle);
    font-weight: 300;
    margin-bottom: 3rem;
    max-width: 500px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-flow: dense;
    gap: 1.6rem 1.3rem;
  }

  /* Inklistrade foton, som i loggboken */
  .item {
    background: #fffdf6;
    border: 9px solid #fffdf6;
    aspect-ratio: 1;
    position: relative;
    overflow: hidden;
    box-shadow: 0 1px 3px rgba(22, 33, 29, 0.22), 0 5px 14px rgba(22, 33, 29, 0.1);
    transition: transform 0.3s ease;
  }

  .item:nth-child(4n + 1) { transform: rotate(-1.1deg); }
  .item:nth-child(4n + 2) { transform: rotate(0.9deg); }
  .item:nth-child(4n + 3) { transform: rotate(-0.5deg); }
  .item:nth-child(4n)     { transform: rotate(1.2deg); }

  .item:hover { transform: rotate(0deg); }

  .item--featured {
    grid-column: span 2;
    grid-row: span 2;
    aspect-ratio: auto;
  }

  .photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 2rem;
  }

  .placeholder svg { opacity: 0.3; stroke: var(--color-ink); }

  .placeholder-label {
    font-family: var(--font-hand);
    font-size: 0.75rem;
    color: var(--color-text-subtle);
    text-align: center;
    white-space: pre-line;
  }

  @media (max-width: 768px) {
    .grid { grid-template-columns: repeat(2, 1fr); }
    .item--featured { grid-column: span 2; }
  }

</style>
