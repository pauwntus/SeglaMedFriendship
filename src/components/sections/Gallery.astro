---
import { Image } from 'astro:assets';
import { gallery } from '../../data/content';

// Bilder läggs i src/assets/bilder/ och kopplas via `src`-fältet i content.ts.
const files = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/bilder/*.{jpg,jpeg,png,webp,avif,JPG,JPEG,PNG,WEBP,AVIF}',
  { eager: true },
);
const imageFor = (src?: string) =>
  src ? files[`../../assets/bilder/${src}`]?.default : undefined;
---

<section id="bilder">
  <div class="inner">
    <h2 class="section-title reveal" set:html={gallery.title} />
    <p class="intro reveal">{gallery.intro}</p>
    <div class="grid reveal">
      {
        gallery.items.map((item) => {
          const img = imageFor(item.src);
          const featured = 'featured' in item && item.featured;
          return (
            <div class={`item${featured ? ' item--featured' : ''}`}>
              {img ? (
                <Image
                  src={img}
                  alt={item.label.replace(/\n/g, ' ')}
                  widths={featured ? [640, 1024, 1600] : [400, 800]}
                  sizes={
                    featured
                      ? '(max-width: 768px) 100vw, 50vw'
                      : '(max-width: 480px) 100vw, (max-width: 768px) 50vw, 25vw'
                  }
                  class="photo"
                />
              ) : (
                <div class="placeholder">
                  <svg
                    width={featured ? 40 : 28}
                    height={featured ? 40 : 28}
                    viewBox="0 0 40 40"
                    fill="none"
                    aria-hidden="true"
                  >
                    <circle cx="20" cy="20" r="18" stroke="white" stroke-width="1.5" stroke-dasharray="4 3" />
                    <path d="M20 13V27M13 20H27" stroke="white" stroke-width="1.5" />
                  </svg>
                  <div class="placeholder-label">{item.label}</div>
                </div>
              )}
            </div>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  section {
    background: var(--color-ink);
  }

  /* Dark section overrides */
  .section-label { color: color-mix(in srgb, var(--color-sun) 80%, transparent); }
  .section-title { color: white; }

  .intro {
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.5);
    font-weight: 300;
    margin-bottom: 3rem;
    max-width: 500px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-flow: dense;
    gap: 0.5rem;
  }

  .item {
    background: var(--color-sea);
    border-radius: 2px;
    overflow: hidden;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    transition: transform 0.3s;
  }

  .item:hover { transform: scale(0.98); }

  .item--featured {
    grid-column: span 2;
    grid-row: span 2;
    aspect-ratio: auto;
  }

  .photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 2rem;
  }

  .placeholder svg { opacity: 0.4; }

  .placeholder-label {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.3);
    text-align: center;
    white-space: pre-line;
  }

  @media (max-width: 768px) {
    .grid { grid-template-columns: repeat(2, 1fr); }
    .item--featured { grid-column: span 2; }
  }

  @media (max-width: 480px) {
    .grid { grid-template-columns: 1fr; }
    .item--featured { grid-column: span 1; aspect-ratio: 1; }
  }
</style>
