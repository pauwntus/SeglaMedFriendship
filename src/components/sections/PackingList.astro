---
import { packing } from '../../data/content';
---

<section id="pack">
  <div class="inner">
    <div class="section-label reveal">{packing.label}</div>
    <h2 class="section-title reveal" set:html={packing.title} />
    <div class="grid">
      {
        packing.cards.map((card) => (
          <div class={`card reveal${card.snacks ? ' card--snacks' : ''}`}>
            <div class="card-icon">{card.icon}</div>
            <div class="card-title">{card.title}</div>
            <ul class="list">
              {card.items.map((item) => (
                <li class={item.important ? 'important' : ''}>{item.text}</li>
              ))}
            </ul>
            {card.snacks && card.tradition && (
              <div class="tradition">
                <div class="tradition-label">{card.tradition.label}</div>
                <div class="tradition-value">{card.tradition.value}</div>
                <div class="tradition-footer">{card.tradition.footer}</div>
              </div>
            )}
          </div>
        ))
      }
    </div>
    <div class="tip reveal">
      <div class="tip-label">Tips</div>
      <p>{packing.tip}</p>
    </div>
  </div>
</section>

<style>
  section { background: var(--color-foam); }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-top: 3.5rem;
  }

  .card {
    background: white;
    border-top: 3px solid var(--color-sea);
    padding: 2rem;
  }

  .card--snacks {
    background: var(--color-sea);
    border-top-color: var(--color-sun);
    position: relative;
    overflow: hidden;
  }

  .card--snacks::before {
    content: '★ TRADITION ★';
    position: absolute;
    top: 1rem; right: 1rem;
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    color: var(--color-sun);
    opacity: 0.7;
  }

  .card-icon {
    font-size: 1.8rem;
    margin-bottom: 1rem;
  }

  .card-title {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    color: var(--color-sea);
    margin-bottom: 1.2rem;
  }

  .card--snacks .card-title { color: white; }

  .list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .list li {
    font-size: 0.92rem;
    color: #444;
    font-weight: 300;
    line-height: 1.4;
    padding-left: 1.2rem;
    position: relative;
  }

  .list li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--color-salt);
    font-family: var(--font-mono);
  }

  .list li.important { color: var(--color-sea); font-weight: 400; }
  .list li.important::before { color: var(--color-sun); }

  .card--snacks .list li { color: rgba(255, 255, 255, 0.65); }
  .card--snacks .list li.important { color: white; }
  .card--snacks .list li::before { color: rgba(255, 255, 255, 0.2); }

  .tradition {
    margin-top: 1.5rem;
    padding-top: 1.2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.15);
  }

  .tradition-label {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-sun);
    margin-bottom: 0.4rem;
  }

  .tradition-value {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-style: italic;
    color: white;
  }

  .tradition-footer {
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.35);
    margin-top: 0.8rem;
    font-weight: 300;
    font-style: italic;
  }

  .tip {
    margin-top: 2rem;
    border-left: 3px solid var(--color-sun);
    padding: 1.5rem 2rem;
    background: white;
  }

  .tip-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-horizon);
    margin-bottom: 0.5rem;
  }

  .tip p {
    font-size: 0.95rem;
    color: #444;
    line-height: 1.7;
    font-weight: 300;
  }

  @media (max-width: 768px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
