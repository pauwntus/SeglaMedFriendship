---
import { rules } from '../../data/content';
---

<section id="regler">
  <div class="inner">
    <h2 class="section-title reveal" set:html={rules.title} />
    <div class="grid reveal">
      {
        rules.items.map((rule) => (
          <div class="rule">
            <div class="rule-num">{rule.num}</div>
            <div class="rule-title">{rule.title}</div>
            <div class="rule-desc">{rule.desc}</div>
          </div>
        ))
      }
    </div>
    <div class="emergency reveal">
      <div class="emergency-label">Nödsituation</div>
      <div class="emergency-body">
        Vid nödläge: <a class="emergency-phone" href={rules.emergency.phoneHref}>{rules.emergency.phone}</a>
        <span class="emergency-hint">({rules.emergency.phoneNote})</span> &nbsp;·&nbsp;
        Nödrop: <strong>{rules.emergency.mayday}</strong>
      </div>
      <div class="emergency-body">
        {rules.emergency.ssrsLabel}: <a class="emergency-phone" href={rules.emergency.ssrsHref}>{rules.emergency.ssrsPhone}</a>
      </div>
      <div class="emergency-note">{rules.emergency.note}</div>
    </div>
  </div>
</section>

<style>

  .grid {
    margin: 3.5rem auto 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 3rem;
  }

  .rule {
    padding: 2rem 0;
  }

  .rule-num {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    color: var(--color-sun-deep);
    margin-bottom: 0.7rem;
  }

  .rule-title {
    font-family: var(--font-hand);
    font-size: 1.05rem;
    color: var(--color-sea);
    margin-bottom: 0.6rem;
  }

  .rule-desc {
    font-size: 0.88rem;
    color: var(--color-text-body);
    line-height: 1.6;
    font-weight: 500;
  }

  .emergency {
    margin-top: 2.5rem;
    padding: 2rem;
    background: var(--color-sea);
  }

  .emergency-label {
    font-family: var(--font-hand);
    font-size: 0.95rem;
    letter-spacing: 0.05em;
    color: var(--color-sun-soft);
    margin-bottom: 0.9rem;
  }

  .emergency-body {
    color: rgba(255, 255, 255, 0.92);
    font-size: 1rem;
    line-height: 1.9;
    font-weight: 500;
  }

  .emergency-body strong { color: white; font-weight: 600; }

  .emergency-phone {
    color: white;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--color-sun-soft);
  }

  .emergency-hint { color: rgba(255, 255, 255, 0.75); }

  .emergency-note {
    margin-top: 0.9rem;
    color: rgba(255, 255, 255, 0.75);
    font-size: 0.9rem;
    line-height: 1.7;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .grid { grid-template-columns: 1fr; }
    .rule { padding: 1.25rem 0; }
  }
</style>
