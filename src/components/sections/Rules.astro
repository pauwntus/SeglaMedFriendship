---
import { rules } from '../../data/content';
---

<section id="regler">
  <div class="inner">
    <div class="section-label reveal">{rules.label}</div>
    <h2 class="section-title reveal" set:html={rules.title} />
    <div class="grid reveal">
      {
        rules.items.map((rule) => (
          <div class="rule">
            <div class="rule-num">{rule.num}</div>
            <div class="rule-title">{rule.title}</div>
            <div class="rule-desc">{rule.desc}</div>
          </div>
        ))
      }
    </div>
    <div class="emergency reveal">
      <div class="emergency-label">Nödsituation</div>
      <div class="emergency-body">
        Sjöräddningen: <strong>{rules.emergency.phone}</strong> &nbsp;·&nbsp;
        {rules.emergency.vhf} &nbsp;·&nbsp; Nödrop: <strong>{rules.emergency.mayday}</strong>
        <br />
        {rules.emergency.note}
      </div>
    </div>
  </div>
</section>

<style>
  section { background: var(--color-sea); }

  /* Dark section overrides */
  .section-label { color: var(--color-sun); opacity: 0.8; }
  .section-title { color: white; }

  .grid {
    margin: 3.5rem auto 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .rule {
    background: rgba(255, 255, 255, 0.04);
    padding: 2rem 2.5rem;
    transition: background 0.2s;
  }

  .rule:hover { background: rgba(255, 255, 255, 0.08); }

  .rule-num {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    color: var(--color-sun);
    margin-bottom: 0.7rem;
  }

  .rule-title {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    color: white;
    margin-bottom: 0.6rem;
  }

  .rule-desc {
    font-size: 0.88rem;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.6;
    font-weight: 300;
  }

  .emergency {
    margin-top: 2.5rem;
    padding: 2rem 2.5rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .emergency-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    color: var(--color-sun);
    margin-bottom: 0.7rem;
  }

  .emergency-body {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.92rem;
    line-height: 1.8;
    font-weight: 300;
  }

  .emergency-body strong { color: white; }

  @media (max-width: 768px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
