---
import { rules } from '../../data/content';
---

<section id="regler">
  <div class="inner">
    <h2 class="section-title reveal" set:html={rules.title} />
    <div class="grid reveal">
      {
        rules.items.map((rule) => (
          <div class="rule">
            <div class="rule-num">{rule.num}</div>
            <div class="rule-title">{rule.title}</div>
            <div class="rule-desc">{rule.desc}</div>
          </div>
        ))
      }
    </div>
    <div class="emergency reveal">
      <div class="emergency-label">Nödsituation</div>
      <div class="emergency-body">
        Sjöräddningen: <strong>{rules.emergency.phone}</strong> &nbsp;·&nbsp;
        {rules.emergency.vhf} &nbsp;·&nbsp; Nödrop: <strong>{rules.emergency.mayday}</strong>
        <br />
        {rules.emergency.ssrs}
        <br />
        {rules.emergency.note}
      </div>
    </div>
  </div>
</section>

<style>

  .grid {
    margin: 3.5rem auto 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 3rem;
  }

  .rule {
    padding: 2rem 0;
  }

  .rule-num {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    color: var(--color-sun);
    margin-bottom: 0.7rem;
  }

  .rule-title {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    color: var(--color-sea);
    margin-bottom: 0.6rem;
  }

  .rule-desc {
    font-size: 0.88rem;
    color: var(--color-text-body);
    line-height: 1.6;
    font-weight: 300;
  }

  .emergency {
    margin-top: 2.5rem;
    padding: 2rem 0;
  }

  .emergency-label {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    color: var(--color-horizon);
    margin-bottom: 0.7rem;
  }

  .emergency-body {
    color: var(--color-text-body);
    font-size: 0.92rem;
    line-height: 1.8;
    font-weight: 300;
  }

  .emergency-body strong { color: var(--color-sea); }

  @media (max-width: 768px) {
    .grid { grid-template-columns: 1fr; }
    .rule { padding: 1.25rem 0; }
  }
</style>
