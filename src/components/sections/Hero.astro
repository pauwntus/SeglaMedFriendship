---
import { boat } from '../../data/content';
---

<section class="hero">
  <div class="content">
    <h1 class="title">
      <em>{boat.prefix}</em>{boat.name}
    </h1>
    <div class="subtitle">
      {boat.type}<br />{boat.club}<br />{boat.area}
    </div>
  </div>

  <div class="wave" aria-hidden="true">
    <svg viewBox="0 0 1440 40" preserveAspectRatio="none">
      <path
        d="M0 22 C 60 10, 120 32, 180 20 S 300 8, 360 22 S 480 34, 540 20 S 660 8, 720 22 S 840 32, 900 18 S 1020 10, 1080 24 S 1200 32, 1260 18 S 1380 10, 1440 22"
        fill="none"
        stroke="#16211d"
        stroke-width="3"
        stroke-linecap="round"
      />
    </svg>
  </div>
</section>

<style>
  .hero {
    min-height: 46vh;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    background: var(--color-light);
    padding: 0;
  }

  .content {
    padding: 7rem var(--section-x) 2rem;
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  h1.title {
    font-family: var(--font-hand);
    font-size: clamp(2.8rem, 6.5vw, 5.5rem);
    color: var(--color-ink);
    line-height: 1.05;
    font-weight: 400;
  }

  h1.title em {
    font-style: normal;
    display: block;
    font-size: 0.4em;
    margin-bottom: 0.2em;
    color: var(--color-text-subtle);
  }

  .subtitle {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
    max-width: 220px;
    text-align: right;
    line-height: 1.8;
  }

  .wave {
    width: 100%;
    height: 40px;
    margin-bottom: 1.5rem;
  }

  .wave svg {
    width: 100%;
    height: 100%;
  }

  @media (max-width: 768px) {
    .hero { min-height: 40vh; }

    .content {
      padding: 6rem 1.5rem 1.5rem;
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }

    .subtitle { text-align: left; max-width: none; }
  }
</style>
