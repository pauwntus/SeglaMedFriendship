---
import { boat } from '../../data/content';
---

<section class="hero">
  <div class="ocean"></div>
  <div class="stars" id="stars"></div>

  <div class="waves" aria-hidden="true">
    <div class="wave wave-1">
      <svg viewBox="0 0 1440 120" preserveAspectRatio="none">
        <path d="M0,60 C240,100 480,20 720,60 C960,100 1200,20 1440,60 L1440,120 L0,120 Z" fill="rgba(30,58,95,0.8)"/>
      </svg>
    </div>
    <div class="wave wave-2">
      <svg viewBox="0 0 1440 120" preserveAspectRatio="none">
        <path d="M0,40 C360,90 720,10 1080,50 C1260,70 1380,30 1440,40 L1440,120 L0,120 Z" fill="rgba(13,33,55,0.9)"/>
      </svg>
    </div>
    <div class="wave wave-3">
      <svg viewBox="0 0 1440 120" preserveAspectRatio="none">
        <path d="M0,80 C180,30 360,90 720,50 C900,30 1080,80 1440,60 L1440,120 L0,120 Z" fill="rgba(10,25,45,0.95)"/>
      </svg>
    </div>
  </div>

  <div class="content">
    <h1 class="title">
      <em>{boat.prefix}</em>{boat.name}
    </h1>
    <div class="subtitle">
      {boat.type}<br />{boat.club}<br />{boat.area}
    </div>
  </div>


</section>

<script>
  const starsEl = document.getElementById('stars')!;
  for (let i = 0; i < 60; i++) {
    const s = document.createElement('div');
    s.className = 'star';
    s.style.left = Math.random() * 100 + '%';
    s.style.top  = Math.random() * 70 + '%';
    s.style.setProperty('--d',     (2 + Math.random() * 4) + 's');
    s.style.setProperty('--delay', (-Math.random() * 4) + 's');
    starsEl.appendChild(s);
  }
</script>

<style>
  .hero {
    height: 50vh;
    min-height: 320px;
    position: relative;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    background: var(--color-sea);
    padding: 0;
  }

  .ocean {
    position: absolute;
    inset: 0;
    background: linear-gradient(175deg, #0d2137 0%, #1e3a5f 35%, #2d5f8a 65%, #4a7fa5 85%, #6ba3c4 100%);
  }

  .stars {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  :global(.star) {
    position: absolute;
    width: 2px;
    height: 2px;
    background: white;
    border-radius: 50%;
    animation: twinkle var(--d, 3s) ease-in-out infinite var(--delay, 0s);
    opacity: 0;
  }

  @keyframes twinkle {
    0%, 100% { opacity: 0; transform: scale(0.8); }
    50%       { opacity: 0.8; transform: scale(1.2); }
  }

  .waves {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 80px;
    overflow: hidden;
  }

  .wave {
    position: absolute;
    bottom: 0;
    width: 200%;
    height: 100%;
  }

  .wave svg { width: 100%; height: 100%; }

  .wave-1 { animation: wave 8s linear infinite;         opacity: 0.6; }
  .wave-2 { animation: wave 12s linear infinite reverse; opacity: 0.4; }
  .wave-3 { animation: wave 6s linear infinite;          opacity: 0.3; }

  @keyframes wave {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .content {
    position: relative;
    z-index: 10;
    padding: 2.5rem var(--section-x);
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  h1.title {
    font-family: var(--font-serif);
    font-size: clamp(3.5rem, 8vw, 7rem);
    color: white;
    line-height: 0.9;
    font-weight: 400;
  }

  h1.title em {
    font-style: normal;
    color: white;
    display: block;
    font-size: 0.45em;
    margin-bottom: 0.3em;
    letter-spacing: 0.05em;
  }

  .subtitle {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    max-width: 200px;
    text-align: right;
    line-height: 1.8;
  }

  @media (max-width: 768px) {
    .content {
      padding: 2rem 1.5rem;
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
    .subtitle { text-align: left; max-width: none; }
  }
</style>
