---
import { boat } from '../../data/content';
---

<section class="hero">
  <div class="ocean"></div>
  <div class="waves" aria-hidden="true">
    <div class="wave wave-1">
      <svg viewBox="0 0 1440 120" preserveAspectRatio="none">
        <path d="M0,60 C240,100 480,20 720,60 C960,100 1200,20 1440,60 L1440,120 L0,120 Z" fill="rgba(30,58,95,0.8)"/>
      </svg>
    </div>
  </div>

  <div class="content">
    <h1 class="title">
      <em>{boat.prefix}</em>{boat.name}
    </h1>
    <div class="subtitle">
      {boat.type}<br />{boat.club}<br />{boat.area}
    </div>
  </div>


</section>


<style>
  .hero {
    height: 50vh;
    min-height: 320px;
    position: relative;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    background: var(--color-sea);
    padding: 0;
  }

  .ocean {
    position: absolute;
    inset: 0;
    background: linear-gradient(175deg, #0d2137 0%, #1e3a5f 35%, #2d5f8a 65%, #4a7fa5 85%, #6ba3c4 100%);
  }

  .waves {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 80px;
    overflow: hidden;
  }

  .wave {
    position: absolute;
    bottom: 0;
    width: 200%;
    height: 100%;
  }

  .wave svg { width: 100%; height: 100%; }

  .wave-1 { animation: wave 8s linear infinite; opacity: 0.8; }

  @keyframes wave {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .content {
    position: relative;
    z-index: 10;
    padding: 2.5rem var(--section-x);
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  h1.title {
    font-family: var(--font-serif);
    font-size: clamp(3.5rem, 8vw, 7rem);
    color: white;
    line-height: 0.9;
    font-weight: 400;
  }

  h1.title em {
    font-style: normal;
    color: white;
    display: block;
    font-size: 0.45em;
    margin-bottom: 0.3em;
    letter-spacing: 0.05em;
  }

  .subtitle {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.8);
    max-width: 200px;
    text-align: right;
    line-height: 1.8;
  }

  @media (max-width: 768px) {
    .content {
      padding: 2rem 1.5rem;
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
    .subtitle { text-align: left; max-width: none; }
  }
</style>
